{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "title": {
    "text": "Monthly Fire Danger Index by Decade",
    "subtitle": "Each ring = one decade (innermost 1970s → outermost 2010s) · Each segment = one month · Colour = FFDI 90th percentile",
    "color": "#d8d0c4",
    "subtitleColor": "#9f9484",
    "font": "DM Sans, sans-serif",
    "subtitleFont": "DM Sans, sans-serif",
    "fontSize": 14,
    "subtitleFontSize": 12,
    "anchor": "start"
  },
  "config": {
    "view": { "stroke": "transparent" },
    "font": "DM Sans, sans-serif",
    "legend": {
      "labelColor": "#b2a48e",
      "titleColor": "#d8d0c4",
      "labelFont": "DM Sans, sans-serif",
      "titleFont": "DM Sans, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  },
  "width": 500,
  "height": 500,
  "data": { "url": "../data/ffdi_polar.csv" },
  "transform": [
    {
      "calculate": "{'Jan':0,'Feb':1,'Mar':2,'Apr':3,'May':4,'Jun':5,'Jul':6,'Aug':7,'Sep':8,'Oct':9,'Nov':10,'Dec':11}[datum.month]",
      "as": "month_i"
    }
  ],
  "encoding": {
    "color": {
      "field": "ffdi_90th",
      "type": "quantitative",
      "scale": {
        "domain": [10, 30],
        "range": ["#2a0a00", "#5d2006", "#921a11", "#be2f18", "#d65c0c", "#ff7a30"]
      },
      "legend": {
        "title": "FFDI (90th pct)",
        "gradientLength": 200,
        "orient": "none",
        "legendY": 100,
        "legendX": 545,
        "titlePadding": 10
      }
    }
  },
  "layer": [
    {
      "description": "1970s ring",
      "transform": [ { "filter": "datum.decade == '1970s'" } ],
      "mark": { "type": "arc", "innerRadius": 30, "stroke": "#0d0b09", "strokeWidth": 1.0 },
      "encoding": {
        "theta": { "field": "month_i", "type": "ordinal", "sort": "ascending", "band": 0.92 },
        "radius": { "value": 64 },
        "tooltip": [
          { "field": "month", "title": "Month" },
          { "field": "decade", "title": "Decade" },
          { "field": "ffdi_90th", "title": "FFDI (90th pct)", "format": ".1f" }
        ]
      }
    },
    {
      "description": "1980s ring",
      "transform": [ { "filter": "datum.decade == '1980s'" } ],
      "mark": { "type": "arc", "innerRadius": 66, "stroke": "#0d0b09", "strokeWidth": 1.0 },
      "encoding": {
        "theta": { "field": "month_i", "type": "ordinal", "sort": "ascending", "band": 0.92 },
        "radius": { "value": 100 },
        "tooltip": [
          { "field": "month", "title": "Month" },
          { "field": "decade", "title": "Decade" },
          { "field": "ffdi_90th", "title": "FFDI (90th pct)", "format": ".1f" }
        ]
      }
    },
    {
      "description": "1990s ring",
      "transform": [ { "filter": "datum.decade == '1990s'" } ],
      "mark": { "type": "arc", "innerRadius": 102, "stroke": "#0d0b09", "strokeWidth": 1.0 },
      "encoding": {
        "theta": { "field": "month_i", "type": "ordinal", "sort": "ascending", "band": 0.92 },
        "radius": { "value": 136 },
        "tooltip": [
          { "field": "month", "title": "Month" },
          { "field": "decade", "title": "Decade" },
          { "field": "ffdi_90th", "title": "FFDI (90th pct)", "format": ".1f" }
        ]
      }
    },
    {
      "description": "2000s ring",
      "transform": [ { "filter": "datum.decade == '2000s'" } ],
      "mark": { "type": "arc", "innerRadius": 138, "stroke": "#0d0b09", "strokeWidth": 1.0 },
      "encoding": {
        "theta": { "field": "month_i", "type": "ordinal", "sort": "ascending", "band": 0.92 },
        "radius": { "value": 172 },
        "tooltip": [
          { "field": "month", "title": "Month" },
          { "field": "decade", "title": "Decade" },
          { "field": "ffdi_90th", "title": "FFDI (90th pct)", "format": ".1f" }
        ]
      }
    },
    {
      "description": "2010s ring",
      "transform": [ { "filter": "datum.decade == '2010s'" } ],
      "mark": { "type": "arc", "innerRadius": 174, "stroke": "#0d0b09", "strokeWidth": 1.0 },
      "encoding": {
        "theta": { "field": "month_i", "type": "ordinal", "sort": "ascending", "band": 0.92 },
        "radius": { "value": 208 },
        "tooltip": [
          { "field": "month", "title": "Month" },
          { "field": "decade", "title": "Decade" },
          { "field": "ffdi_90th", "title": "FFDI (90th pct)", "format": ".1f" }
        ]
      }
    },
    {
      "description": "Month labels",
      "transform": [ { "filter": "datum.decade == '2010s'" } ],
      "mark": { "type": "text", "fontSize": 11, "fontWeight": 500, "align": "center", "baseline": "middle" },
      "encoding": {
        "theta": { "field": "month_i", "type": "ordinal", "sort": "ascending", "band": 0.5 },
        "radius": { "value": 224 },
        "text": { "field": "month", "type": "nominal" },
        "color": { "value": "#b2a48e" }
      }
    },
    {
      "description": "Decade labels",
      "mark": { "type": "text", "fontSize": 9, "align": "right", "baseline": "middle", "dx": -5 },
      "encoding": {
        "theta": { "value": 4.712 },
        "radius": {
          "field": "r", "type": "quantitative",
          "scale": { "domain": [0, 250], "rangeMin": 0, "rangeMax": 250 }
        },
        "text": { "field": "label", "type": "nominal" },
        "color": { "value": "#7d7160" }
      }
    },
    {
      "description": "January pointer arrow",
      "data": { "values": [{ "month_i": 0 }] },
      "mark": { "type": "text", "text": "➔", "fontSize": 12, "angle": 130, "align": "left" },
      "encoding": {
        "theta": { "field": "month_i", "type": "ordinal", "band": 0.8 },
        "radius": { "value": 240 },
        "color": { "value": "#ff7a30" }
      }
    },
    {
      "description": "January annotation text",
      "data": { "values": [{ "month_i": 0 }] },
      "mark": {
        "type": "text",
        "text": ["January Peak:", "Max summer heat &", "accumulated dry fuel"],
        "fontSize": 12,
        "align": "left",
        "baseline": "top",
        "dx": 20,
        "dy": -12,
        "lineHeight": 13
      },
      "encoding": {
        "theta": { "field": "month_i", "type": "ordinal", "band": 0.8 },
        "radius": { "value": 240 },
        "color": { "value": "#9f9484" }
      }
    },
    {
      "description": "Winter pointer arrow",
      "data": { "values": [{ "month_i": 5 }] },
      "mark": { "type": "text", "text": "➔", "fontSize": 12, "angle": -110, "align": "left" },
      "encoding": {
        "theta": { "field": "month_i", "type": "ordinal", "band": 0.5 },
        "radius": { "value": 240 },
        "color": { "value": "#6ab0d4" }
      }
    },
    {
      "description": "Winter annotation text",
      "data": { "values": [{ "month_i": 5 }] },
      "mark": {
        "type": "text",
        "text": ["Winter months:", "Cooler temps reduce", "fire danger significantly"],
        "fontSize": 12,
        "align": "left",
        "baseline": "top",
        "dx": 20,
        "dy": -18,
        "lineHeight": 13
      },
      "encoding": {
        "theta": { "field": "month_i", "type": "ordinal", "band": 0.5 },
        "radius": { "value": 240 },
        "color": { "value": "#6ab0d4" }
      }
    }
  ]
}
