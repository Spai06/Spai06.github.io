{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Fire Danger Index Heatmap Strip, Southern Australia 1971–2017",
  "data": {
    "url": "../Data/ffdi_annual.csv"
  },
  "width": "container",
  "height": 180,
  "transform": [
    {
      "calculate": "datum.year < 1980 ? '1970s' : datum.year < 1990 ? '1980s' : datum.year < 2000 ? '1990s' : datum.year < 2010 ? '2000s' : '2010s'",
      "as": "decade"
    },
    {
      "calculate": "datum.year === 1980 || datum.year === 1990 || datum.year === 2000 || datum.year === 2010",
      "as": "is_decade_start"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rect",
        "width": {"band": 0.95}
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "title": "Year",
            "labelAngle": -45,
            "labelFontSize": 10,
            "titleFontSize": 12,
            "labelColor": "#b2a48e",
            "titleColor": "#d8d0c4",
            "tickColor": "#4a4030",
            "domainColor": "#4a4030",
            "labelOverlap": "parity"
          }
        },
        "color": {
          "field": "ffdi_90th",
          "type": "quantitative",
          "scale": {
            "domain": [13, 25],
            "range": ["#2a0a00", "#5d2006", "#921a11", "#be2f18", "#d65c0c", "#ff7a30", "#ffcc00"]
          },
          "legend": {
            "title": "FFDI (90th pct)",
            "titleColor": "#d8d0c4",
            "labelColor": "#b2a48e",
            "titleFontSize": 11,
            "labelFontSize": 10,
            "orient": "right",
            "gradientLength": 120,
            "gradientThickness": 10
          }
        },
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "ffdi_90th", "type": "quantitative", "format": ".2f", "title": "FFDI 90th pct"},
          {"field": "decade", "type": "nominal", "title": "Decade"}
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year === 1980 || datum.year === 1990 || datum.year === 2000 || datum.year === 2010"
        }
      ],
      "mark": {
        "type": "rule",
        "color": "#0d0b09",
        "strokeWidth": 2.5,
        "opacity": 0.9
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year === 1980 || datum.year === 1990 || datum.year === 2000 || datum.year === 2010"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4,
        "dy": -62,
        "fontSize": 9,
        "fontWeight": "bold",
        "opacity": 0.6
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "text": {
          "field": "decade",
          "type": "nominal"
        },
        "color": {"value": "#d8d0c4"}
      }
    },
    {
      "transform": [
        {"filter": "datum.year === 2009"}
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "dy": -80,
        "fontSize": 10,
        "fontWeight": "bold",
        "color": "#ffcc00",
        "lineBreak": "\n"
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "text": {"value": "▼ Peak\n2009: 23.8"}
      }
    },
    {
      "transform": [
        {"filter": "datum.year === 2009"}
      ],
      "mark": {
        "type": "rule",
        "color": "#ffcc00",
        "strokeWidth": 1,
        "strokeDash": [3, 2],
        "opacity": 0.5,
        "y": 0,
        "y2": {"expr": "height"}
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"}
      }
    },
    {
      "transform": [
        {"filter": "datum.year === 1971"}
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4,
        "dy": -62,
        "fontSize": 9,
        "fontWeight": "bold",
        "opacity": 0.6
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "text": {"value": "1970s"},
        "color": {"value": "#d8d0c4"}
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {
      "stroke": "transparent"
    },
    "font": "DM Sans, sans-serif",
    "axis": {
      "domainColor": "#3a3020",
      "gridColor": "#1e1912",
      "tickColor": "#3a3020"
    }
  }
}
