{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 800,
  "height": 450,
  "background": "transparent",
  "padding": {"left": 30, "right": 20, "top": 20, "bottom": 10},
  "data": { "url": "../Data/abares_summary.csv" },
  "transform": [
    { "filter": "datum.state !== 'NT'" }
  ],
  "layer": [
    {
      "params": [
        {
          "name": "state_highlight",
          "select": {"type": "point", "fields": ["state"]},
          "bind": "legend"
        }
      ],
      "mark": { 
        "type": "area", 
        "interpolate": "monotone",
        "stroke": "#1a1208",
        "strokeWidth": 0.5
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "scale": {"padding": 0},
          "axis": {
            "title": "Fire Season",
            "labelColor": "#b2a48e",
            "titleColor": "#b2a48e",
            "gridColor": "#2e2619",
            "labelFontSize": 12,
            "titleFontSize": 13,
            "titlePadding": 15,
            "labelAngle": 0,
            "tickColor": "#4a4030",
            "domainColor": "#4a4030"
          }
        },
        "y": {
          "field": "hectares",
          "type": "quantitative",
          "stack": "center",
          "axis": {
            "title": "Area Burned (Hectares, Streamgraph Baseline)",
            "labelColor": "#b2a48e",
            "titleColor": "#b2a48e",
            "gridColor": "#2e2619",
            "gridOpacity": 0.3,
            "titleFontSize": 13,
            "titlePadding": 15,
            "format": "~s",
            "tickColor": "#4a4030",
            "domainColor": "#4a4030"
          }
        },
        "color": {
          "field": "state",
          "type": "nominal",
          "scale": {
            "domain": ["Tas", "WA", "Vic", "NSW", "Qld", "SA", "ACT"],
            "range": ["#2ca02c", "#9467bd", "#1f77b4", "#d62728", "#ff7f0e", "#8c564b", "#e377c2"]
          },
          "legend": {
            "title": "State",
            "titleColor": "#d8d0c4",
            "titleFontSize": 18,
            "titleFontWeight": "bold",
            "titlePadding": 10,
            "labelColor": "#b2a48e",
            "labelFontSize": 16,
            "labelHeight": 22,
            "symbolType": "circle",
            "symbolSize": 100,
            "offset": 25,
            "labelExpr": "upper(datum.label)"
          }
        },
        "opacity": {
          "condition": {"param": "state_highlight", "value": 0.9},
          "value": 0.15
        },
        "tooltip": [
          { "field": "state", "title": "State" },
          { "field": "year", "title": "Season" },
          { "field": "hectares", "title": "Hectares Burned", "format": ",.0f" }
        ]
      }
    },
    {
      "transform": [
        { "window": [{"op": "row_number", "as": "row"}], "frame": [null, null] },
        { "filter": "datum.row == 1" }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "fontSize": 11,
        "fontWeight": 500,
        "lineHeight": 14,
        "color": "#ffb066"
      },
      "encoding": {
        "x": { "value": 110 },
        "y": { "value": 45 },
        "text": {
          "value": [
            "Queensland Savannah Cycle",
            "Northern grassland fires dominate the",
            "majority of early baseline acreage."
          ]
        }
      }
    },
    {
      "data": { "values": [{}] },
      "mark": {
        "type": "rule",
        "stroke": "#ffb066",
        "strokeWidth": 1.2
      },
      "encoding": {
        "x": { "value": 240 },
        "y": { "value": 95 },
        "x2": { "value": 248 },
        "y2": { "value": 125 }
      }
    },
    {
      "data": { "values": [{}] },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 10,
        "color": "#ffb066",
        "angle": 165
      },
      "encoding": {
        "x": { "value": 249 },
        "y": { "value": 128 },
        "text": { "value": "▲" }
      }
    },
    {
      "transform": [
        { "window": [{"op": "row_number", "as": "row"}], "frame": [null, null] },
        { "filter": "datum.row == 1" }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "fontSize": 11,
        "fontWeight": 500,
        "lineHeight": 14,
        "color": "#e1d8c9"
      },
      "encoding": {
        "x": { "value": 150 },
        "y": { "value": 415 },
        "text": {
          "value": [
            "Southern Forest Suppression",
            "Thinner coastal state bands (Vic/WA/SA)",
            "prior to major drought accelerations."
          ]
        }
      }
    },
    {
      "data": { "values": [{}] },
      "mark": {
        "type": "rule",
        "stroke": "#e1d8c9",
        "strokeWidth": 1.2
      },
      "encoding": {
        "x": { "value": 255 },
        "y": { "value": 375 },
        "y2": { "value": 345 }
      }
    },
    {
      "data": { "values": [{}] },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 10,
        "color": "#e1d8c9"
      },
      "encoding": {
        "x": { "value": 255 },
        "y": { "value": 343 },
        "text": { "value": "▲" }
      }
    }
  ],
  "config": {
    "view": { "stroke": "transparent" },
    "text": {
      "font": "DM Sans, system-ui, -apple-system, sans-serif"
    },
    "axis": {
      "labelFont": "DM Sans, system-ui, -apple-system, sans-serif",
      "titleFont": "DM Sans, system-ui, -apple-system, sans-serif"
    },
    "legend": {
      "labelFont": "DM Sans, system-ui, -apple-system, sans-serif",
      "titleFont": "DM Sans, system-ui, -apple-system, sans-serif"
    }
  }
}